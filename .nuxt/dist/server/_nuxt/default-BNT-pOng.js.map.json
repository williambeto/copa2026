{"file":"default-BNT-pOng.js","mappings":";;;;;;;;;;;AAEA,MAAM,SAAS,IAAI,IAAI;AAEhB,SAAS,WAAW;AAsBzB,WAAS,cAAc;AACrB,WAAO,QAAQ,CAAC,OAAO;AAAA,EACzB;AAEA,SAAO,EAAE,QAAQ,YAAA;AACnB;;;;;ACbA,UAAM,EAAE,QAAAA,QAAoB,IAAI,SAAA;;;QAhB5B,MAAK;AAAA,QACL,OAAM;AAAA,QACL,cAAYC,MAAAD,OAAA,IAAM,sBAAA;AAAA,QAClB,OAAOC,MAAAD,OAAA,IAAM,sBAAA;AAAA,MAAA,uHAMVC,MAAAD,OAAA,IAAM,OAAA,IAAA;;;;;;;;;;ACTP,SAAS,aAAa,YAAsB;AACjD,QAAM,gBAAgB,IAAY,EAAE;AA0BpC,SAAO,EAAE,cAAA;AACX;;;;;ACsFA,UAAM,EAAE,kBAAkB,aAAuB;AAEjD,UAAM,iBAAiB,IAAI,KAAK;AAgBhC,UAAM,WAAsB;AAAA,MAC1B,EAAE,IAAI,UAAU,OAAO,UAAU,MAAM,UAAA;AAAA,MACvC,EAAE,IAAI,eAAe,OAAO,eAAe,MAAM,eAAA;AAAA,MACjD,EAAE,IAAI,WAAW,OAAO,WAAW,MAAM,WAAA;AAAA,MACzC,EAAE,IAAI,YAAY,OAAO,YAAY,MAAM,YAAA;AAAA,MAC3C,EAAE,IAAI,aAAa,OAAO,aAAa,MAAM,aAAA;AAAA,MAC7C,EAAE,IAAI,eAAe,OAAO,eAAe,MAAM,eAAA;AAAA,MACjD,EAAE,IAAI,UAAU,OAAO,UAAU,MAAM,UAAA;AAAA,IAAU;;;;QA3I/C,OAAM;AAAA,QACN,MAAK;AAAA,MAAA;AAqBsBE,oBAAA,WAAR,SAAI;qCAEV,QAAM,KAAK,IAAI,4BAERD,MAAA,aAAA,MAAkB,KAAK,iLAG9BE,cAAA,gBAAcF,MAAA,aAAA,MAAkB,KAAK,cAAc,MAAS,KAE1DG,eAAA,KAAK,KAAK;;;;;;AA6BhB,YAAA,qQAAAD,cAAA,iBAAe,eAAA,KAAc,CAAA,oEAAA;WAKjB,eAAA,OAAc;;;;;iFAUvB,eAAA,QAAc,6BAAA,yCAAA,mEAAA,CAAA,KACrBA,cAAA,gBAAc,eAAA,KAAc;AAIND,oBAAA,WAAR,SAAI;qCAEV,QAAM,KAAK,IAAI,4BAERD,MAAA,aAAA,MAAkB,KAAK,yLAG9BE,cAAA,gBAAcF,MAAA,aAAA,MAAkB,KAAK,cAAc,MAAS,KAG1DG,eAAA,KAAK,KAAK;;;;;;;;;;;;;;;IC1FzB,OAAM;AAAA,IACN,MAAK;AAAA;;;;;;;;;;;;;ACkBT,UAAM,UAAU,IAAI,KAAK;;;QAjBnB,MAAK;AAAA,QACL,OAAM;AAAA,QACN,cAAW;AAAA,QACX,OAAM;AAAA,MAAA;eAJE,QAAA,QAAO,OAAA,EAAA,SAAA,OAAA;AAAA,MAAA;;;;;;;;;;;;;;;ACWrB,UAAM,EAAE,QAAAJ,QAAA,IAAW,SAAA;;;;;;QAbZ,OAAK,CAAC,2EAAyE,EAAA,SAAA,CAAqBC,MAAAD,OAAA,EAAA,CAAM;AAAA,MAAA;;;;;;;;;;;;;;;;;","names":["isDark","_unref","_ssrRenderList","_ssrRenderAttr","_ssrInterpolate"],"sources":["../../../../app/composables/useTheme.ts","../../../../app/components/ThemeToggle.vue","../../../../app/composables/useScrollSpy.ts","../../../../app/components/SiteHeader.vue","../../../../app/components/SiteFooter.vue","../../../../app/components/BackToTop.vue","../../../../app/layouts/default.vue"],"sourcesContent":["import { ref, watchEffect } from 'vue'\n\nconst isDark = ref(true)\n\nexport function useTheme() {\n  if (process.client) {\n    const stored = localStorage.getItem('wc2026-theme')\n    if (stored !== null) {\n      isDark.value = stored === 'dark'\n    }\n\n    watchEffect(() => {\n      const html = document.documentElement\n      if (isDark.value) {\n        html.classList.add('dark')\n        html.classList.remove('light')\n        document.body.classList.remove('light')\n      } else {\n        html.classList.remove('dark')\n        html.classList.add('light')\n        document.body.classList.add('light')\n      }\n      localStorage.setItem('wc2026-theme', isDark.value ? 'dark' : 'light')\n    })\n  }\n\n  function toggleTheme() {\n    isDark.value = !isDark.value\n  }\n\n  return { isDark, toggleTheme }\n}\n","<template>\n  <button\n    type=\"button\"\n    class=\"inline-flex items-center justify-center w-9 h-9 rounded-lg text-lg transition-colors duration-200 hover:bg-marine-800/50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500 group\"\n    :aria-label=\"isDark ? 'Ativar modo claro' : 'Ativar modo escuro'\"\n    :title=\"isDark ? 'Ativar modo claro' : 'Ativar modo escuro'\"\n    @click=\"toggleTheme\"\n  >\n    <span\n      aria-hidden=\"true\"\n      class=\"transition-transform duration-300 group-hover:scale-110\"\n    >{{ isDark ? '☀️' : '🌙' }}</span>\n  </button>\n</template>\n\n<script setup lang=\"ts\">\nimport { useTheme } from '~/composables/useTheme'\n\nconst { isDark, toggleTheme } = useTheme()\n</script>\n","import { ref, onMounted, onUnmounted } from 'vue'\n\nexport function useScrollSpy(sectionIds: string[]) {\n  const activeSection = ref<string>('')\n\n  let observer: IntersectionObserver | null = null\n\n  onMounted(() => {\n    observer = new IntersectionObserver(\n      (entries) => {\n        for (const entry of entries) {\n          if (entry.isIntersecting) {\n            activeSection.value = entry.target.id\n          }\n        }\n      },\n      { rootMargin: '-20% 0px -70% 0px', threshold: 0 }\n    )\n\n    for (const id of sectionIds) {\n      const el = document.getElementById(id)\n      if (el) observer.observe(el)\n    }\n  })\n\n  onUnmounted(() => {\n    observer?.disconnect()\n  })\n\n  return { activeSection }\n}\n","<template>\n  <header\n    class=\"fixed top-0 left-0 right-0 z-50 bg-marine-900/95 backdrop-blur-md border-b border-marine-800/60 transition-colors duration-300\"\n    role=\"banner\"\n  >\n    <nav\n      class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"\n      aria-label=\"Navegação principal\"\n    >\n      <div class=\"flex items-center justify-between h-16 lg:h-18\">\n        <!-- Logo -->\n        <a\n          href=\"#\"\n          class=\"flex-shrink-0 group\"\n          aria-label=\"Ir para o topo da página\"\n        >\n          <span class=\"text-lg sm:text-xl font-extrabold font-mono tracking-tight text-gold-500 group-hover:text-gold-400 transition-colors duration-200\">\n            World Cup 2026 Intelligence\n          </span>\n        </a>\n\n        <!-- Desktop nav -->\n        <div class=\"hidden lg:flex lg:items-center lg:gap-1\">\n          <ul class=\"flex items-center gap-1\">\n            <li v-for=\"item in navItems\" :key=\"item.id\">\n              <a\n                :href=\"item.href\"\n                class=\"px-3 py-2 rounded-lg text-sm font-medium transition-colors duration-200\"\n                :class=\"activeSection === item.id\n                  ? 'text-gold-500 bg-gold-500/10'\n                  : 'text-gray-300 hover:text-gold-400 hover:bg-marine-800/50'\"\n                :aria-current=\"activeSection === item.id ? 'true' : undefined\"\n              >\n                {{ item.label }}\n              </a>\n            </li>\n          </ul>\n\n          <!-- Separator -->\n          <div class=\"h-6 w-px bg-marine-700 mx-2\" aria-hidden=\"true\" />\n\n          <!-- Theme toggle -->\n          <ThemeToggle />\n\n          <!-- Data badge -->\n          <div\n            class=\"ml-3 inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-marine-800/80 border border-marine-700/50 text-xs text-gray-400 font-mono\"\n            aria-label=\"Data da última atualização dos dados\"\n          >\n            <span class=\"h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse\" aria-hidden=\"true\" />\n            <span>Dados atualizados em 12 de junho de 2026</span>\n          </div>\n        </div>\n\n        <!-- Mobile controls -->\n        <div class=\"flex items-center gap-3 lg:hidden\">\n          <ThemeToggle />\n\n          <!-- Hamburger button -->\n          <button\n            type=\"button\"\n            class=\"inline-flex items-center justify-center p-2 rounded-lg text-gray-300 hover:text-gold-400 hover:bg-marine-800/50 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500\"\n            :aria-expanded=\"mobileMenuOpen\"\n            aria-controls=\"mobile-menu\"\n            aria-label=\"Abrir menu de navegação\"\n            @click=\"toggleMobileMenu\"\n          >\n            <span v-if=\"!mobileMenuOpen\" class=\"text-2xl leading-none\" aria-hidden=\"true\">&#9776;</span>\n            <span v-else class=\"text-2xl leading-none\" aria-hidden=\"true\">&#10005;</span>\n          </button>\n        </div>\n      </div>\n\n      <!-- Mobile menu -->\n      <div\n        id=\"mobile-menu\"\n        class=\"lg:hidden overflow-hidden transition-all duration-300 ease-in-out\"\n        :class=\"mobileMenuOpen ? 'max-h-screen opacity-100' : 'max-h-0 opacity-0 pointer-events-none'\"\n        :aria-hidden=\"!mobileMenuOpen\"\n      >\n        <div class=\"py-3 border-t border-marine-800/60\">\n          <ul class=\"space-y-1 pb-2\">\n            <li v-for=\"item in navItems\" :key=\"item.id\">\n              <a\n                :href=\"item.href\"\n                class=\"block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors duration-200\"\n                :class=\"activeSection === item.id\n                  ? 'text-gold-500 bg-gold-500/10'\n                  : 'text-gray-300 hover:text-gold-400 hover:bg-marine-800/50'\"\n                :aria-current=\"activeSection === item.id ? 'true' : undefined\"\n                @click=\"closeMobileMenu\"\n              >\n                {{ item.label }}\n              </a>\n            </li>\n          </ul>\n\n          <!-- Mobile data badge -->\n          <div\n            class=\"mx-4 mt-2 inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-marine-800/80 border border-marine-700/50 text-xs text-gray-400 font-mono\"\n          >\n            <span class=\"h-1.5 w-1.5 rounded-full bg-green-500 animate-pulse\" aria-hidden=\"true\" />\n            <span>Dados atualizados em 12 de junho de 2026</span>\n          </div>\n        </div>\n      </div>\n    </nav>\n  </header>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref } from 'vue'\nimport { useScrollSpy } from '~/composables/useScrollSpy'\n\nconst sectionIds = ['resumo', 'comparativo', 'ranking', 'analises', 'surpresas', 'metodologia', 'fontes']\n\nconst { activeSection } = useScrollSpy(sectionIds)\n\nconst mobileMenuOpen = ref(false)\n\nfunction toggleMobileMenu() {\n  mobileMenuOpen.value = !mobileMenuOpen.value\n}\n\nfunction closeMobileMenu() {\n  mobileMenuOpen.value = false\n}\n\ninterface NavItem {\n  id: string\n  label: string\n  href: string\n}\n\nconst navItems: NavItem[] = [\n  { id: 'resumo', label: 'Resumo', href: '#resumo' },\n  { id: 'comparativo', label: 'Comparativo', href: '#comparativo' },\n  { id: 'ranking', label: 'Ranking', href: '#ranking' },\n  { id: 'analises', label: 'Análises', href: '#analises' },\n  { id: 'surpresas', label: 'Surpresas', href: '#surpresas' },\n  { id: 'metodologia', label: 'Metodologia', href: '#metodologia' },\n  { id: 'fontes', label: 'Fontes', href: '#fontes' },\n]\n</script>\n","<template>\n  <footer\n    class=\"border-t border-marine-800/60 bg-marine-950 transition-colors duration-300\"\n    role=\"contentinfo\"\n  >\n    <div class=\"section-container py-12 lg:py-16\">\n      <div class=\"grid sm:grid-cols-2 lg:grid-cols-3 gap-10\">\n        <!-- Brand -->\n        <div class=\"space-y-4\">\n          <p class=\"text-lg font-extrabold font-mono text-gold-500\">\n            World Cup 2026 Intelligence\n          </p>\n          <p class=\"text-sm text-gray-400 leading-relaxed\">\n            Análise editorial independente. Dados compilados de fontes públicas.\n            Atualizado em 12 de junho de 2026.\n          </p>\n        </div>\n\n        <!-- Links -->\n        <div class=\"space-y-4\">\n          <h3 class=\"text-sm font-semibold text-gray-300 uppercase tracking-wider\">\n            Navegação\n          </h3>\n          <ul class=\"space-y-2\">\n            <li>\n              <a\n                href=\"#metodologia\"\n                class=\"text-sm text-gray-400 hover:text-gold-400 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500\"\n              >\n                Metodologia\n              </a>\n            </li>\n            <li>\n              <a\n                href=\"#fontes\"\n                class=\"text-sm text-gray-400 hover:text-gold-400 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500\"\n              >\n                Fontes\n              </a>\n            </li>\n            <li>\n              <a\n                href=\"#ranking\"\n                class=\"text-sm text-gray-400 hover:text-gold-400 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500\"\n              >\n                Ranking completo\n              </a>\n            </li>\n            <li>\n              <a\n                href=\"#resumo\"\n                class=\"text-sm text-gray-400 hover:text-gold-400 transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold-500\"\n              >\n                Início\n              </a>\n            </li>\n          </ul>\n        </div>\n\n        <!-- Disclaimer -->\n        <div class=\"space-y-4 sm:col-span-2 lg:col-span-1\">\n          <h3 class=\"text-sm font-semibold text-gray-300 uppercase tracking-wider\">\n            Aviso importante\n          </h3>\n          <div\n            class=\"p-4 rounded-lg border border-gold-500/20 bg-marine-900/60\"\n          >\n            <p class=\"text-xs text-gray-400 leading-relaxed\">\n              As probabilidades apresentadas são estimativas analíticas e não representam\n              recomendações financeiras ou de aposta. Este é um projeto editorial independente\n              com fins informativos.\n            </p>\n          </div>\n        </div>\n      </div>\n\n      <!-- Bottom bar -->\n      <div class=\"mt-12 pt-6 border-t border-marine-800/60 flex flex-col sm:flex-row items-center justify-between gap-3\">\n        <p class=\"text-xs text-gray-500\">\n          &copy; 2026 World Cup 2026 Intelligence. Todos os direitos reservados.\n        </p>\n        <p class=\"text-xs text-gray-600 font-mono\">\n          Edição de 12 de junho de 2026\n        </p>\n      </div>\n    </div>\n  </footer>\n</template>\n","<template>\n  <transition name=\"bt-fade\">\n    <button\n      v-show=\"visible\"\n      type=\"button\"\n      class=\"fixed bottom-6 right-6 z-40 inline-flex items-center justify-center w-11 h-11 rounded-full bg-marine-800 border border-gold-500/40 text-gold-500 shadow-lg shadow-marine-950/50 transition-all duration-300 hover:bg-marine-700 hover:border-gold-500 hover:scale-105 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-gold-500 motion-reduce:transition-none\"\n      aria-label=\"Voltar ao topo da página\"\n      title=\"Voltar ao topo\"\n      @click=\"scrollToTop\"\n    >\n      <span\n        class=\"text-xl font-bold leading-none select-none\"\n        aria-hidden=\"true\"\n      >&uarr;</span>\n    </button>\n  </transition>\n</template>\n\n<script setup lang=\"ts\">\nimport { ref, onMounted, onUnmounted } from 'vue'\n\nconst visible = ref(false)\n\nfunction onScroll() {\n  visible.value = window.scrollY > 300\n}\n\nfunction scrollToTop() {\n  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches\n  window.scrollTo({\n    top: 0,\n    behavior: prefersReducedMotion ? 'auto' : 'smooth',\n  })\n}\n\nonMounted(() => {\n  window.addEventListener('scroll', onScroll, { passive: true })\n})\n\nonUnmounted(() => {\n  window.removeEventListener('scroll', onScroll)\n})\n</script>\n\n<style scoped>\n.bt-fade-enter-active,\n.bt-fade-leave-active {\n  transition: opacity 0.3s ease, transform 0.3s ease;\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .bt-fade-enter-active,\n  .bt-fade-leave-active {\n    transition: none;\n  }\n}\n\n.bt-fade-enter-from,\n.bt-fade-leave-to {\n  opacity: 0;\n  transform: translateY(12px);\n}\n</style>\n","<template>\n  <div class=\"min-h-screen bg-marine-950 text-gray-200 transition-colors duration-300\" :class=\"{ 'light': !isDark }\">\n    <SiteHeader />\n    <main id=\"main-content\">\n      <slot />\n    </main>\n    <SiteFooter />\n    <BackToTop />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { useTheme } from '~/composables/useTheme'\n\nconst { isDark } = useTheme()\n</script>\n"],"version":3}