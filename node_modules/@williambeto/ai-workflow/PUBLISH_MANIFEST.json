{
  "name": "ai-workflow-publish-manifest",
  "version": "1.0.0",
  "layers": {
    "core": [
      "bin/**",
      "src/**",
      "package.json",
      "opencode.jsonc"
    ],
    "assets": [
      "dist-assets/skills/**",
      "dist-assets/agents/**",
      "dist-assets/commands/**",
      "dist-assets/prompts/**",
      "dist-assets/templates/**",
      "dist-assets/schemas/**",
      "dist-assets/runbooks/**",
      "dist-assets/harness/**",
      "dist-assets/docs/**",
      "dist-assets/examples/**",
      "dist-assets/AGENTS.md"
    ]
  },
  "exclude": [
    "internal/**",
    "**/tests/**",
    "**/evidence/**",
    "**/*.original.md",
    ".git/**",
    ".ai-workflow/**",
    "node_modules/**"
  ]
}
