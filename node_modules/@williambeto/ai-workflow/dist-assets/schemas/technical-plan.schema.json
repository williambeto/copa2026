{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/technical-plan.schema.json",
  "title": "Technical Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "architectureSummary",
    "filesInScope",
    "filesOutOfScope",
    "implementationSteps",
    "dependencies",
    "risks",
    "tradeoffs",
    "validationPlan",
    "rollbackPlan"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "architectureSummary": {
      "type": "string",
      "minLength": 1
    },
    "filesInScope": {
      "$ref": "#/$defs/fileArray"
    },
    "filesOutOfScope": {
      "$ref": "#/$defs/fileArray"
    },
    "implementationSteps": {
      "$ref": "#/$defs/stringArray"
    },
    "dependencies": {
      "$ref": "#/$defs/stringArray"
    },
    "risks": {
      "$ref": "#/$defs/stringArray"
    },
    "tradeoffs": {
      "$ref": "#/$defs/stringArray"
    },
    "validationPlan": {
      "$ref": "#/$defs/stringArray"
    },
    "rollbackPlan": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fileArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

