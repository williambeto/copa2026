{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/handoff.schema.json",
  "title": "Agent Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sourceAgent",
    "targetAgent",
    "objective",
    "context",
    "decisionsAlreadyMade",
    "filesInScope",
    "filesOutOfScope",
    "constraints",
    "validationRequired",
    "knownRisks",
    "stopConditions",
    "expectedOutput"
  ],
  "properties": {
    "sourceAgent": {
      "type": "string",
      "minLength": 1
    },
    "targetAgent": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "string",
      "minLength": 1
    },
    "decisionsAlreadyMade": {
      "$ref": "#/$defs/stringArray"
    },
    "filesInScope": {
      "$ref": "#/$defs/fileArray"
    },
    "filesOutOfScope": {
      "$ref": "#/$defs/fileArray"
    },
    "constraints": {
      "$ref": "#/$defs/stringArray"
    },
    "validationRequired": {
      "$ref": "#/$defs/stringArray"
    },
    "knownRisks": {
      "$ref": "#/$defs/stringArray"
    },
    "stopConditions": {
      "$ref": "#/$defs/stringArray"
    },
    "expectedOutput": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fileArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

