{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/functional-spec.schema.json",
  "title": "Functional Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "userStories",
    "functionalRequirements",
    "states",
    "errors",
    "edgeCases",
    "acceptanceCriteria",
    "outOfScope"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "userStories": {
      "$ref": "#/$defs/stringArray"
    },
    "functionalRequirements": {
      "$ref": "#/$defs/stringArray"
    },
    "states": {
      "$ref": "#/$defs/stringArray"
    },
    "errors": {
      "$ref": "#/$defs/stringArray"
    },
    "edgeCases": {
      "$ref": "#/$defs/stringArray"
    },
    "acceptanceCriteria": {
      "$ref": "#/$defs/stringArray"
    },
    "outOfScope": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

