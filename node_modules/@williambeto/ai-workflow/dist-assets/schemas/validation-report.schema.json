{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/validation-report.schema.json",
  "title": "Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "status",
    "commandsRun",
    "checks",
    "issues",
    "remainingRisks",
    "recommendation"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "passed",
        "passed-with-notes",
        "failed",
        "blocked",
        "not-run"
      ]
    },
    "commandsRun": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "command",
          "result"
        ],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "$ref": "#/$defs/checkArray"
    },
    "issues": {
      "$ref": "#/$defs/issueArray"
    },
    "remainingRisks": {
      "$ref": "#/$defs/stringArray"
    },
    "recommendation": {
      "enum": [
        "Approved",
        "Approved with notes",
        "Changes requested",
        "Blocked"
      ]
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checkArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "result",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "enum": [
              "pass",
              "fail",
              "not-run",
              "not-applicable"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "issueArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "type",
          "finding",
          "recommendation"
        ],
        "properties": {
          "severity": {
            "enum": [
              "High",
              "Medium",
              "Low"
            ]
          },
          "type": {
            "enum": [
              "Confirmed issue",
              "Hypothesis",
              "Observation"
            ]
          },
          "finding": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

