{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/pr-breakdown.schema.json",
  "title": "PR Breakdown",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "strategy",
    "prs"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "strategy": {
      "type": "string",
      "minLength": 1
    },
    "prs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "goal",
          "scope",
          "filesLikelyChanged",
          "validation",
          "risks",
          "dependencies",
          "estimatedSize"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "goal": {
            "type": "string",
            "minLength": 1
          },
          "scope": {
            "$ref": "#/$defs/stringArray"
          },
          "filesLikelyChanged": {
            "$ref": "#/$defs/stringArray"
          },
          "validation": {
            "$ref": "#/$defs/stringArray"
          },
          "risks": {
            "$ref": "#/$defs/stringArray"
          },
          "dependencies": {
            "$ref": "#/$defs/stringArray"
          },
          "estimatedSize": {
            "enum": [
              "small",
              "medium",
              "large"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

