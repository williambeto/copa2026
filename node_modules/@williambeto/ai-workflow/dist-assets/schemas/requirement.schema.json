{
  "$id": "https://github.com/williambeto/ai-workflow/schemas/requirement.schema.json",
  "title": "Requirement",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "problem",
    "goal",
    "users",
    "scope",
    "outOfScope",
    "acceptanceCriteria",
    "risks",
    "openQuestions"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "users": {
      "$ref": "#/$defs/stringArray"
    },
    "scope": {
      "$ref": "#/$defs/stringArray"
    },
    "outOfScope": {
      "$ref": "#/$defs/stringArray"
    },
    "assumptions": {
      "$ref": "#/$defs/stringArray"
    },
    "constraints": {
      "$ref": "#/$defs/stringArray"
    },
    "acceptanceCriteria": {
      "$ref": "#/$defs/stringArray"
    },
    "risks": {
      "$ref": "#/$defs/riskArray"
    },
    "openQuestions": {
      "$ref": "#/$defs/stringArray"
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "riskArray": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "risk",
          "impact",
          "mitigation"
        ],
        "properties": {
          "risk": {
            "type": "string",
            "minLength": 1
          },
          "impact": {
            "type": "string",
            "minLength": 1
          },
          "mitigation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

